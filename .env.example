# =============================================================================
# WorkshopPro NZ — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# --- Application ---
APP_NAME=WorkshopPro NZ
DEBUG=true
ENVIRONMENT=development

# --- Database (PostgreSQL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=workshoppro
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/workshoppro

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT / Auth ---
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_REMEMBER_DAYS=30

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Carjam ---
CARJAM_API_KEY=
CARJAM_BASE_URL=https://api.carjam.co.nz
CARJAM_GLOBAL_RATE_LIMIT_PER_MINUTE=60

# --- Email (Brevo / SendGrid / SMTP) ---
SMTP_API_KEY=
SMTP_FROM_EMAIL=noreply@workshoppro.nz
SMTP_FROM_NAME=WorkshopPro NZ

# --- Twilio SMS ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SENDER_NUMBER=

# --- Xero ---
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# --- MYOB ---
MYOB_CLIENT_ID=
MYOB_CLIENT_SECRET=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Encryption ---
ENCRYPTION_MASTER_KEY=change-me-in-production

# --- Rate Limiting ---
RATE_LIMIT_PER_USER_PER_MINUTE=100
RATE_LIMIT_PER_ORG_PER_MINUTE=1000
RATE_LIMIT_AUTH_PER_IP_PER_MINUTE=10

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173"]
