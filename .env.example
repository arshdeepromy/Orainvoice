# =============================================================================
# OraInvoice / WorkshopPro NZ — Environment Variables
# Copy this file to .env and fill in the values for your environment.
#
# ARCHITECTURE:
#   docker compose up → single entry point on port 80 (APP_PORT)
#   Point your Nginx Proxy Manager (or any reverse proxy) at this port.
#   The app handles API routing internally — one port, any domain.
#
# ENVIRONMENT VALUES:
#   development → enables debug docs, dev seeding, relaxed rate limits
#   production  → disables dev features, enforces real secrets
# =============================================================================

# --- Application ---
APP_NAME=OraInvoice
DEBUG=false
ENVIRONMENT=production

# --- Exposed port (the single port your reverse proxy points to) ---
APP_PORT=80

# --- Database (PostgreSQL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=workshoppro
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@postgres:5432/workshoppro

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT / Auth ---
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_REMEMBER_DAYS=30

# --- Firebase (MFA phone auth) ---
FIREBASE_PROJECT_ID=

# --- Encryption ---
ENCRYPTION_MASTER_KEY=CHANGE_ME_GENERATE_A_RANDOM_KEY

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# --- Carjam ---
CARJAM_API_KEY=
CARJAM_BASE_URL=https://www.carjam.co.nz
CARJAM_GLOBAL_RATE_LIMIT_PER_MINUTE=60

# --- Email (Brevo / SendGrid / SMTP) ---
SMTP_API_KEY=
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=OraInvoice

# --- Twilio SMS ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SENDER_NUMBER=

# --- Xero ---
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# --- MYOB ---
MYOB_CLIENT_ID=
MYOB_CLIENT_SECRET=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Rate Limiting ---
RATE_LIMIT_PER_USER_PER_MINUTE=100
RATE_LIMIT_PER_ORG_PER_MINUTE=1000
RATE_LIMIT_AUTH_PER_IP_PER_MINUTE=10

# --- CORS (add your domain — the URL users access the app from) ---
CORS_ORIGINS=["https://yourdomain.com"]

# --- Frontend base URL (the public URL users see) ---
FRONTEND_BASE_URL=https://yourdomain.com

# --- Vite HMR (dev only — set when behind a reverse proxy) ---
# HMR_HOST=yourdomain.com
# HMR_CLIENT_PORT=443
# HMR_PROTOCOL=wss

# --- WebAuthn / Passkeys ---
WEBAUTHN_RP_ID=yourdomain.com
WEBAUTHN_RP_NAME=OraInvoice
WEBAUTHN_ORIGIN=https://yourdomain.com

# --- HA Replication ---
# Shared HMAC secret for heartbeat signing (must be identical on both nodes)
HA_HEARTBEAT_SECRET=
# PostgreSQL connection string for the PEER's database (used for logical replication)
# Format: postgresql://<user>:<password>@<peer_ip>:<peer_pg_port>/<db_name>
# Dev example: postgresql://postgres:postgres@host.docker.internal:5434/workshoppro
# Prod example: postgresql://replication_user:<password>@192.168.1.91:5432/workshoppro
HA_PEER_DB_URL=
