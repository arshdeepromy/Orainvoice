# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Ensure shell scripts always have LF line endings (required for Docker/Linux)
*.sh text eol=lf
scripts/docker-entrypoint.sh text eol=lf

# Binary files — don't touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.dump binary
*.tar binary
*.gz binary
